{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "module": "nodenext",
    "target": "esnext",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src"]
}
